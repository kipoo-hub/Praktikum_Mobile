<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F6"
    tools:context=".pertemuan_5.FifthActivity">

    <!-- 🌿 TOOLBAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="4dp">


        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#3AA17E"
            app:title="Pertemuan 5 🌿"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white"
            app:layout_scrollFlags="scroll|enterAlways"
            app:menu="@menu/menu_option"/>

    </com.google.android.material.appbar.AppBarLayout>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang 🌿"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#2E4F4F"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eksplor fitur WebView dengan tampilan modern."
                android:textSize="14sp"
                android:textColor="#6B8E8E"
                android:layout_marginBottom="24dp"/>

            <!-- 🔥 CARD UTAMA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@android:color/white">

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_home"
                        android:background="#E8F5E9"
                        android:padding="14dp"
                        android:layout_marginBottom="20dp" />

                    <!-- TITLE -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WebView Module"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2E4F4F"
                        android:gravity="center"
                        android:layout_marginBottom="8dp"/>

                    <!-- DESC -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Menampilkan website langsung di dalam aplikasi Android dengan performa optimal."
                        android:textSize="14sp"
                        android:textColor="#6B8E8E"
                        android:gravity="center"
                        android:layout_marginBottom="24dp"/>

                    <!-- 🔥 BUTTON IMPROVISASI -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWeb"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="Buka WebView"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#3AA17E"
                        app:cornerRadius="20dp"
                        app:icon="@android:drawable/ic_menu_view"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:rippleColor="#A5D6A7"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 🔥 CARD INFO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#E8F5E9"
                app:strokeColor="#A5D6A7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🌱"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tip: Scroll dan Explore dongg Biar Ga Rugii!!."
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:textColor="#2E7D32"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
