<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    tools:context=".Home.HomeFragment">

    <!-- TODO: Update blank fragment layout -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Ini Fragment Home"
        android:textAlignment="center"
        android:background="#FF6800"
        android:textStyle="italic"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToSecond"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:text="Pertemuan 2: Kalkulator"
        android:backgroundTint="@color/red"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToThird"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:text="Pertemuan 3: Activity &amp; Intent"
        app:backgroundTint="@color/red"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToFourth"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:text="Pertemuan 4: Dashboard Travel"
        app:backgroundTint="@color/red"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToFifth"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:text="Pertemuan 5: Web View PCR"
        app:backgroundTint="@color/red"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToSixth"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pertemuan 6: Fragment Dasar"
        app:backgroundTint="@color/red"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToNinth"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pertemuan 9"
        app:backgroundTint="@color/red"
        app:cornerRadius="12dp" />

    </LinearLayout>
    </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>